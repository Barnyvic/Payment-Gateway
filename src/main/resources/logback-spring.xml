<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="sanitizedMsg" class="com.paymentgateway.common.logging.SanitizingMessageConverter"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} - %sanitizedMsg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
